   "source": [
    "class Solution(object):\n",
    "    def subarraySum(self, nums, k):\n",
    "        res = 0\n",
    "        for i in range(len(nums)):\n",
    "            current_sum = sum(nums[i:]) \n",
    "            if current_sum == k:\n",
    "                res = current_sum  \n",
    "        return res"
   ]
  }
