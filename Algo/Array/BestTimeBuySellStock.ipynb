   "source": [
    "def maxProfit(prices):\n",
    "    min_price = float(\"inf\")\n",
    "    max_profit = 0\n",
    "    for price in prices:\n",
    "        min_price = min(min_price, price)\n",
    "        profit = price - min_price\n",
    "        max_profit = max(max_profit, profit)\n",
    "    return max_profit\n",
    "\n",
    "maxProfit(prices=[9,3,8,1,3,4,2,7,9,8])"
   ]
  }
 ],
