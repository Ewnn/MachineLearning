    "def maxSum():\n",
    "    t = [2, 3, -8, 7, -1, 2, 3]\n",
    "    res = float('-inf')\n",
    "    for i in range(len(t)):\n",
    "        current_sum = sum(t[i:]) \n",
    "        if current_sum > res:\n",
    "            res = current_sum  \n",
    "    return res\n",
    "\n",
    "maxSum()"
   ]
  }
