   "source": [
    "def twoSum(nums, target):\n",
    "    storage = {}  \n",
    "    for i, num in enumerate(nums):\n",
    "        complement = target - num\n",
    "        if complement in storage:\n",
    "            return [storage[complement], i]\n",
    "        storage[num] = i\n",
    "    return []\n",
    "twoSum(nums = [2,7,11,15], target = 26)"
   ]
  }
 ],
