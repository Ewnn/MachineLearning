   "source": [
    "def hasCycle(self, head: Optional[ListNode]) -> bool:\n",
    "    slow = head\n",
    "    fast = head\n",
    "\n",
    "    while fast and fast.next:\n",
    "        slow = slow.next\n",
    "        fast = fast.next.next\n",
    "    if slow == fast:\n",
    "        return True            \n",
    "    return False        "
   ]
  }
